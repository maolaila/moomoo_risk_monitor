    {
      "id": "holding-risk-news-search",
      "name": "Holding Risk News Search",
      "enabled": true,
      "adapter": "search_rss",
      "tier": "fast",
      "category": "search",
      "cadenceMinutes": 10,
      "urlTemplate": "https://www.bing.com/news/search?q={query}&format=rss",
      "perTicker": true,
      "maxQueries": 24,
      "maxItems": 20,
      "queries": [
        "{ticker} stock offering dilution convertible notes guidance cut lawsuit investigation",
        "{ticker} export control tariff sanction China semiconductor AI data center",
        "\"{name}\" \"{ticker}\" earnings guidance revenue margin",
        "{ticker} HBM GPU accelerator optical transceiver silicon photonics AI infrastructure supply chain"
      ]
    },
