# Runtime
RISK_MONITOR_ENABLED=true
RISK_MONITOR_INTERVAL_MINUTES=10
RISK_MONITOR_HEARTBEAT_SECONDS=30
RISK_MONITOR_TIMEZONE=Asia/Tokyo
RISK_ALERT_MIN_SEVERITY=HIGH
RISK_MONITOR_DATA_DIR=./data/risk-monitor
NEWS_POOL_CLEANUP_ENABLED=true
NEWS_POOL_RETENTION_HOURS=24
AI_REPAIR_ENABLED=true
AI_REPAIR_ALLOW_CODE_EDITS=true
AI_REPAIR_COOLDOWN_MINUTES=30
AI_REPAIR_TIMEOUT_MS=600000
AI_REPAIR_RECENT_LOG_LINES=80
AI_REPAIR_SCHEMA=schemas/ai_repair.schema.json
AI_REPAIR_VALIDATION_COMMANDS=npm run build,npm test
SOURCE_REGISTRY_ENABLED=true
SOURCE_REGISTRY_PATH=./config/sources.json
SOCIAL_WATCHLIST_ENABLED=true
SOCIAL_WATCHLIST_AUTO_UPDATE=true
SOCIAL_WATCHLIST_PATH=./data/risk-monitor/social-watchlist.json
SOCIAL_WATCHLIST_SCHEMA=schemas/social_watchlist.schema.json

# Email alerts. Gmail requires an App Password, not the normal login password.
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_TO=maolaila1+moomoo-risk-monitor@gmail.com
ALERT_EMAIL_FROM="Moomoo Risk Monitor <maolaila2@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=maolaila2@gmail.com
SMTP_PASS_FILE=./secrets/gmail_app_password.txt
# SMTP_PASS=only_use_this_if_you_do_not_want_a_secret_file

# Moomoo holdings snapshot
MOOMOO_REPORTS_DIR=../moomoo_trade_reports
MOOMOO_SNAPSHOT_DIR=

# Event sources
ENABLE_SEC_MONITOR=true
ENABLE_RSS_MONITOR=true
ENABLE_POLICY_RSS_MONITOR=true
ENABLE_TICKER_NEWS_MONITOR=true
ENABLE_SOCIAL_MONITOR=true
ENABLE_NEWSAPI_MONITOR=false
ENABLE_ALPHA_VANTAGE_MONITOR=false
ENABLE_PRICE_MONITOR=false
SEC_LOOKBACK_DAYS=7
NEWS_LOOKBACK_HOURS=48

# RSS/news/policy/social feeds. Use comma-separated URLs.
RISK_MONITOR_RSS_FEEDS=https://seekingalpha.com/market_currents.xml,https://www.cnbc.com/id/100003114/device/rss/rss.html,https://www.marketwatch.com/rss/topstories
RISK_MONITOR_POLICY_FEEDS=https://www.whitehouse.gov/briefings-statements/feed/,https://www.federalreserve.gov/feeds/press_all.xml,https://www.federalreserve.gov/feeds/speeches.xml
RISK_MONITOR_SOCIAL_FEEDS=https://truthsocial.com/@realDonaldTrump.rss
NEWS_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Codex risk analysis
CODEX_ENABLED=true
CODEX_RISK_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=xhigh
CODEX_SPEED_TIER=fast
CODEX_SERVICE_TIER=fast
CODEX_APPROVAL_POLICY=never
CODEX_SANDBOX=read-only
CODEX_TIMEOUT_MS=120000
CODEX_OUTPUT_SCHEMA=schemas/risk_analysis.schema.json

# SEC polite User-Agent contact. Do not put secrets here.
SEC_CONTACT_EMAIL=contact@example.com
