{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "severity",
    "can_continue",
    "probable_cause",
    "repair_summary",
    "recommended_steps",
    "suggested_commands",
    "needs_human",
    "risk_notes"
  ],
  "additionalProperties": false,
  "properties": {
    "severity": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "can_continue": {
      "type": "boolean"
    },
    "probable_cause": {
      "type": "string"
    },
    "repair_summary": {
      "type": "string"
    },
    "recommended_steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggested_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "needs_human": {
      "type": "boolean"
    },
    "risk_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
