{
  "type": "object",
  "properties": {
    "ticker": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": ["bullish", "bearish", "neutral", "mixed", "unknown"]
    },
    "severity": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "should_email": {
      "type": "boolean"
    },
    "one_sentence_summary": {
      "type": "string"
    },
    "why_it_matters": {
      "type": "string"
    },
    "portfolio_impact": {
      "type": "string"
    },
    "suggested_action": {
      "type": "string",
      "enum": ["ignore", "watch", "manual_review", "reduce_risk_candidate", "urgent_manual_review"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "claim": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": ["source", "claim"],
        "additionalProperties": false
      }
    },
    "missing_data": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "ticker",
    "direction",
    "severity",
    "confidence",
    "should_email",
    "one_sentence_summary",
    "why_it_matters",
    "portfolio_impact",
    "suggested_action",
    "evidence",
    "missing_data"
  ],
  "additionalProperties": false
}
